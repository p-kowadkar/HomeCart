# Expo reads this at build time (npx expo prebuild) -- not committed to git
# Copy to .env and fill in values

# Your backend LAN IP for device testing (e.g. http://192.168.1.x:8000)
EXPO_PUBLIC_API_URL=http://localhost:8000

# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps -- used by app.config.js at prebuild time (baked into native binary, NOT exposed to JS)
GOOGLE_MAPS_API_KEY=
